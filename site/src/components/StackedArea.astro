---
// Stacked area over a numeric x (years). series = [[x, v1, v2, …vN]] aligned
// to `keys` (labels). Colors cycle the categorical slots in fixed order; a
// legend always carries identity, a table view carries the numbers.
import { linePath, scale, ticks } from "../lib/scale.js";
import { num } from "../lib/format.js";

const {
  title,
  sub = "",
  series = [],
  keys = [],
  w = 520,
  h = 220,
  fmt = num,
  unit = "",
  ordinal = false, // ordered categories (e.g. regime) use a sequential ramp
} = Astro.props;

// nominal: validated 5-slot categorical order (blue peach teal mauve pink);
// ordinal: a single-hue sequential ramp so the order reads in the color
const colorOf = (ki) => (ordinal ? `var(--seq${(ki % 4) + 1})` : `var(--c${(ki % 5) + 1})`);
const PAD = { l: 48, r: 10, t: 10, b: 22 };
const totals = series.map((r) => r.slice(1).reduce((a, b) => a + b, 0));
const tks = ticks(Math.max(...totals, 1));
const yMax = tks[tks.length - 1];
const x = scale(series[0]?.[0] ?? 0, series[series.length - 1]?.[0] ?? 1, PAD.l, w - PAD.r);
const y = scale(0, yMax, h - PAD.b, PAD.t);

// build cumulative band paths, bottom-up
const bands = keys.map((_, ki) => {
  const top = series.map((r) => [x(r[0]), y(r.slice(1, ki + 2).reduce((a, b) => a + b, 0))]);
  const bot = series.map((r) => [x(r[0]), y(r.slice(1, ki + 1).reduce((a, b) => a + b, 0))]);
  return `${linePath(top)}L${bot.map((p) => `${p[0]},${p[1]}`).reverse().join("L")}Z`;
});
---

<div class="card viz">
  <h3>{title}</h3>
  {sub && <p class="viz-sub">{sub}</p>}
  <div class="viz-scroll">
    <svg width={w} height={h} viewBox={`0 0 ${w} ${h}`} role="img" aria-label={title}>
      {tks.map((t) => (
        <>
          <line class="gridline" x1={PAD.l} x2={w - PAD.r} y1={y(t)} y2={y(t)} />
          <text class="tick-text" x={PAD.l - 6} y={y(t) + 3} text-anchor="end">{fmt(t)}</text>
        </>
      ))}
      {keys.map((k, ki) => (
        <path d={bands[ki]} style={`fill:${colorOf(ki)};opacity:0.85`} />
      ))}
      {series.map((r, i) =>
        i % Math.max(1, Math.round(series.length / 8)) === 0 ? (
          <text class="tick-text" x={x(r[0])} y={h - 6} text-anchor="middle">{r[0]}</text>
        ) : null
      )}
      {series.map((r) => (
        <rect
          class="hit" x={x(r[0]) - 3} y={PAD.t} width="6" height={h - PAD.t - PAD.b} tabindex="0"
          data-tip-value={`${r[0]}`}
          data-tip-label={keys.map((k, ki) => `${k}: ${fmt(r[ki + 1])}`).join(" · ")}
        />
      ))}
    </svg>
  </div>
  <div class="viz-legend">
    {keys.map((k, ki) => (
      <span class="key"><span class="swatch" style={`background:${colorOf(ki)}`}></span> {k}</span>
    ))}
  </div>
  <details class="tableview">
    <summary>table view</summary>
    <table class="data">
      <thead><tr><th>year</th>{keys.map((k) => <th class="n">{k}</th>)}</tr></thead>
      <tbody>
        {series.map((r) => (
          <tr><td>{r[0]}</td>{r.slice(1).map((v) => <td class="n">{fmt(v)}</td>)}</tr>
        ))}
      </tbody>
    </table>
  </details>
</div>
